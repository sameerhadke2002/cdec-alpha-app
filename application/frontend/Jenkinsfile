// Frontend deploy pipeline — build React app, upload to S3, invalidate CloudFront cache
//
// Jenkins setup:
//   1. Node.js 20 and npm on the agent
//   2. AWS CLI on the agent
//   3. AWS credential in Jenkins named: aws-frontend-deploy
//      (needs s3:PutObject, s3:DeleteObject, s3:ListBucket, cloudfront:CreateInvalidation)

pipeline {
    agent {
        label 'node'
    }

    parameters {
        string(
            name: 'S3_BUCKET',
            defaultValue: 'cdec-alpha-frontend-dev-frontend',
            description: 'S3 bucket name for the frontend (e.g. cdec-frontend-dev-frontend)'
        )
        string(
            name: 'CLOUDFRONT_DISTRIBUTION_ID',
            defaultValue: 'E2191Y8O3EGPFM',
            description: 'CloudFront distribution ID (e.g. E1234567890ABC)'
        )
        string(
            name: 'VITE_AUTH_API',
            defaultValue: 'https://api.thecloudnine.in/api/auth',
            description: 'Auth API URL baked into the build'
        )
        string(
            name: 'VITE_COURSE_API',
            defaultValue: 'https://api.thecloudnine.in/api/courses',
            description: 'Course API URL baked into the build'
        )
        string(
            name: 'VITE_ENROLL_API',
            defaultValue: 'https://api.thecloudnine.in/api/enroll',
            description: 'Enrollment API URL baked into the build'
        )
    }

    environment {
        APP_DIR = 'application/frontend'
        AWS_DEFAULT_REGION = 'eu-west-1'
    }

    stages {

        stage('Checkout') {
            steps {
                git url: 'https://github.com/atulyw/cdec-alpha-app.git', branch: 'main'
            }
        }

        stage('Install dependencies') {
            steps {
                dir(env.APP_DIR) {
                    sh 'npm ci'
                }
            }
        }

        stage('Build') {
            steps {
                dir(env.APP_DIR) {
                    sh """
                        export VITE_AUTH_API=${params.VITE_AUTH_API}
                        export VITE_COURSE_API=${params.VITE_COURSE_API}
                        export VITE_ENROLL_API=${params.VITE_ENROLL_API}
                        npm run build
                    """
                }
            }
        }

        stage('Deploy to S3') {
            steps {
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'aws-frontend-terraform',
                    accessKeyVariable: 'AWS_ACCESS_KEY_ID',
                    secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
                ]]) {
                    dir(env.APP_DIR) {
                        sh """
                            echo "Uploading to s3://${params.S3_BUCKET}/"
                            aws s3 sync dist/ s3://${params.S3_BUCKET}/ --delete
                        """
                    }
                }
            }
        }

        stage('Invalidate CloudFront') {
            steps {
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'aws-frontend-terraform',
                    accessKeyVariable: 'AWS_ACCESS_KEY_ID',
                    secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
                ]]) {
                    sh """
                        echo "Invalidating CloudFront distribution ${params.CLOUDFRONT_DISTRIBUTION_ID}"
                        aws cloudfront create-invalidation \\
                            --distribution-id ${params.CLOUDFRONT_DISTRIBUTION_ID} \\
                            --paths "/*"
                    """
                }
            }
        }
    }

    post {
        success {
            echo 'Frontend deployed successfully!'
        }
        failure {
            echo 'Frontend deployment failed. Check the stage logs above.'
        }
    }
}
