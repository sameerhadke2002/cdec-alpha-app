# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
*.swp
*.swo

# Dependencies & build outputs
node_modules/
dist/
build/
out/
target/
*.egg-info/
__pycache__/
.venv/
venv/

# Environment & secrets (never commit)
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
secrets/
credentials.json

# -----------------------------------------------------------------------------
# Terraform (infrastructure/frontend, infrastructure/backend, infrastructure/modules)
# -----------------------------------------------------------------------------
# Provider/plugin cache
**/.terraform/

# State and backups (use S3 remote state — see infrastructure/REMOTE_STATE.md)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Plan output (Jenkins / local runs)
**/tfplan
**/tfplan.*

# Crash and CLI override files
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Real config — copy from committed .example / .sample files
**/terraform.tfvars
**/*.auto.tfvars
**/*.auto.tfvars.json
**/backend.hcl
*.tfvars

# Committed samples (frontend/backend stacks)
!*.tfvars.example
!*.tfvars.sample
!**/terraform.tfvars.example
!**/terraform.tfvars.sample
!**/backend.hcl.example
!**/backend.hcl.sample

# Commit lock files for reproducible init (do not ignore)
# .terraform.lock.hcl

# Docker / K8s local
*.log
.docker/

# Test & coverage
coverage/
.nyc_output/
htmlcov/
.pytest_cache/
.tox/

# Jenkins / CI artifacts
.jenkins/
artifacts/
reports/
